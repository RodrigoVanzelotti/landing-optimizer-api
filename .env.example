NODE_ENV=development
PORT=3001
LOG_LEVEL=info

DATABASE_URL=postgresql://user:password@localhost:5432/landing_optimizer

CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=landing_optimizer
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=redacted

REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me-in-prod-please-32-bytes-min
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# config signing (per-site keys encrypted with this KMS key in prod)
# 32 byte base64 key used to encrypt per-site Ed25519 private keys at rest
CONFIG_ENCRYPTION_KEY=

AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_TOKEN=dev-internal-token

DASHBOARD_ORIGIN=http://localhost:3000

# Public URLs advertised in generated snippets
CDN_SDK_BASE_URL=https://cdn.landing-optimizer.io/sdk
INGEST_URL=http://localhost:3001/events
CONFIG_URL=http://localhost:3001/config
SDK_VERSION=0.1.0

