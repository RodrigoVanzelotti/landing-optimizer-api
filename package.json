    "clickhouse:migrate": "ts-node src/analytics/clickhouse/migrate.ts"
  },
  "dependencies": {
    "@clickhouse/client": "^1.4.0",
    "@fastify/helmet": "^11.1.1",
    "@nestjs/common": "^10.3.9",
    "@nestjs/config": "^3.2.2",
    "@nestjs/core": "^10.3.9",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-fastify": "^10.3.9",
    "@prisma/client": "^5.16.0",
    "argon2": "^0.40.3",
    "ioredis": "^5.4.1",
    "nanoid": "^3.3.7",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^10.0.0",
    "uuidv7": "^0.6.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@types/node": "^20.14.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
